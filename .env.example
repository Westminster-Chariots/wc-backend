# Database
# Neon connection string — swap for AWS RDS Aurora URL when migrating
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-backend-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-backend-secret
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# Email
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Pusher
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=us2

# Google Maps
GOOGLE_MAPS_API_KEY=

# Server
PORT=3001
NODE_ENV=development

# URLs
FRONTEND_URL=https://wc-version2.vercel.app
BACKEND_URL=https://wc-backend-ayx0.onrender.com

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://wc-version2.vercel.app,https://westminsterchariots.com
